{
  "problemMatcher": [
    {
      "owner": "elixir-mixCompileWarning",
      "severity": "warning",
      "pattern": [
        {
          "regexp": "^warning: (.*)$",
          "message": 1
        },
        {
          "regexp": "^  (.*):(\\d+).*$",
          "file": 1,
          "line": 2
        }
      ]
    }
  ]
}
